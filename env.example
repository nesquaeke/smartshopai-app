# Copy to `.env.local` for Next.js (same Supabase project as scraper)
# URL must match `scraper/.env` → SUPABASE_URL exactly.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# Optional: product list polling (ms). 0 = disable.
# NEXT_PUBLIC_PRODUCTS_POLL_MS=60000
